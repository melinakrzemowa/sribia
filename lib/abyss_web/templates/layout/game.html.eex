<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover, minimal-ui">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Sribia">
    <meta name="theme-color" content="#000000">
    <meta name="description" content="Sribia Game">
    <meta name="author" content="">
    <link rel="manifest" href="<%= Routes.static_path(@conn, "/manifest.json") %>">

    <title>Sribia</title>

    <style>
    * {
        -webkit-tap-highlight-color: transparent;
        -webkit-touch-callout: none;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    html, body {
        margin: 0;
        padding: 0;
        overflow: hidden;
        height: 100vh;
        height: 100dvh; /* Dynamic viewport height for mobile */
        width: 100vw;
        position: fixed;
        overscroll-behavior: none;
        touch-action: none;
    }

    body {
        background: #000;
    }

    #game {
        width: 100%;
        height: 100vh;
        height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #000;
        position: relative;
    }

    #messages {
        position: absolute;
        bottom: 60px;
        left: 10px;
        color: yellow;
        z-index: 10;
        font-family: Verdana, Geneva, sans-serif;
        font-weight: bold;
        font-size: 12px;
        list-style: none;
        padding: 0;
        margin: 0;
        pointer-events: none;
    }

    #messages li {
        margin-bottom: 5px;
        transition: opacity 0.5s ease-out;
        pointer-events: none;
    }

    #messages li.fade-out {
        opacity: 0;
    }

    #messages * {
        pointer-events: none;
    }

    #chat-input {
        position: absolute;
        bottom: 10px;
        left: 10px;
        z-index: 10;
        -webkit-user-select: text;
        -moz-user-select: text;
        -ms-user-select: text;
        user-select: text;
    }

    hr {
        display: none;
    }

    small {
        position: absolute;
        bottom: 10px;
        right: 10px;
        color: white;
        z-index: 10;
    }

    /* Portrait orientation warning overlay */
    #portrait-warning {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        height: 100dvh;
        background: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        font-family: Arial, sans-serif;
        text-align: center;
        padding: 20px;
        box-sizing: border-box;
    }

    #portrait-warning.show {
        display: flex;
    }

    .rotate-icon {
        font-size: 80px;
        margin-bottom: 20px;
        animation: rotate 2s ease-in-out infinite;
    }

    @keyframes rotate {
        0%, 100% { transform: rotate(0deg); }
        50% { transform: rotate(90deg); }
    }

    #portrait-warning h2 {
        font-size: 24px;
        margin: 0 0 10px 0;
    }

    #portrait-warning p {
        font-size: 16px;
        margin: 0;
        opacity: 0.8;
    }

    /* Fullscreen button */
    #fullscreen-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 10px 15px;
        border-radius: 8px;
        cursor: pointer;
        z-index: 100;
        font-size: 14px;
        font-weight: bold;
        transition: all 0.3s ease;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    #fullscreen-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        border-color: rgba(255, 255, 255, 0.5);
    }

    #fullscreen-btn:active {
        transform: scale(0.95);
    }

    #fullscreen-btn.hidden {
        display: none;
    }

    /* Hide fullscreen button when in fullscreen */
    :fullscreen #fullscreen-btn,
    :-webkit-full-screen #fullscreen-btn,
    :-moz-full-screen #fullscreen-btn,
    :-ms-fullscreen #fullscreen-btn {
        display: none;
    }

    /* iOS installation prompt */
    #ios-install-prompt {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(0, 0, 0, 0.95);
        color: white;
        padding: 20px;
        z-index: 10000;
        font-family: Arial, sans-serif;
        text-align: center;
        border-top: 2px solid rgba(255, 255, 255, 0.2);
    }

    #ios-install-prompt.show {
        display: block;
    }

    #ios-install-prompt h3 {
        margin: 0 0 10px 0;
        font-size: 18px;
    }

    #ios-install-prompt p {
        margin: 0 0 15px 0;
        font-size: 14px;
        opacity: 0.9;
        line-height: 1.4;
    }

    #ios-install-prompt .instructions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin: 10px 0;
        font-size: 16px;
    }

    #ios-install-prompt button {
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        margin-top: 10px;
        cursor: pointer;
    }

    /* Ensure game scales properly in landscape */
    @media screen and (orientation: landscape) {
        #game canvas {
            max-height: 100vh;
            max-height: 100dvh;
            max-width: 100vw;
        }
    }
    </style>
  </head>

  <body>
    <!-- Portrait orientation warning -->
    <div id="portrait-warning">
      <div class="rotate-icon">📱➜📱</div>
      <h2>Please Rotate Your Device</h2>
      <p>This game is best experienced in landscape mode</p>
    </div>

    <!-- Fullscreen button -->
    <button id="fullscreen-btn">Fullscreen</button>

    <!-- iOS installation prompt -->
    <div id="ios-install-prompt">
      <h3>For the Best Experience</h3>
      <p>Install this app to your home screen for fullscreen gameplay without the address bar</p>
      <div class="instructions">
        Tap <strong>Share</strong>
        <svg width="20" height="24" viewBox="0 0 20 24" fill="white">
          <path d="M10 0L10 15M10 0L6 4M10 0L14 4M3 8v13a2 2 0 002 2h10a2 2 0 002-2V8"/>
        </svg>
        then <strong>"Add to Home Screen"</strong>
      </div>
      <button onclick="document.getElementById('ios-install-prompt').classList.remove('show')">Got it</button>
    </div>

    <%= @inner_content %>

    <div id="messages"></div>
    <input id="chat-input" type="text" />

    <hr/>

    <small>Version: <%= System.get_env("VERSION") %></small>

    <script>window.token = "<%= assigns[:token] %>";</script>
    <script>window.user_id = <%= assigns[:user_id] %>;</script>
    <script src="<%= Routes.static_path(@conn, "/vendor/phaserce.js") %>"></script>
    <script src="<%= Routes.static_path(@conn, "/vendor/phaser-virtual-joystick.min.js") %>"></script>

    <script src="<%= Routes.static_path(@conn, "/js/app.js") %>"></script>

    <script>
      // Mobile orientation and fullscreen handler
      (function() {
        const portraitWarning = document.getElementById('portrait-warning');
        const fullscreenBtn = document.getElementById('fullscreen-btn');
        const iosInstallPrompt = document.getElementById('ios-install-prompt');

        // Detect iOS
        function isIOS() {
          return /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
        }

        // Check if running in standalone mode (installed to home screen)
        function isStandalone() {
          return window.navigator.standalone === true ||
                 window.matchMedia('(display-mode: standalone)').matches;
        }

        // Check if device is mobile
        function isMobile() {
          return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        }

        // Check orientation and show/hide warning
        function checkOrientation() {
          if (!isMobile()) {
            portraitWarning.classList.remove('show');
            return;
          }

          const isPortrait = window.innerHeight > window.innerWidth;

          if (isPortrait) {
            portraitWarning.classList.add('show');
          } else {
            portraitWarning.classList.remove('show');
          }
        }

        // Request fullscreen (doesn't work on iOS Safari)
        function requestFullscreen() {
          const elem = document.documentElement;

          if (elem.requestFullscreen) {
            elem.requestFullscreen();
          } else if (elem.webkitRequestFullscreen) { // Safari (non-iOS)
            elem.webkitRequestFullscreen();
          } else if (elem.mozRequestFullScreen) { // Firefox
            elem.mozRequestFullScreen();
          } else if (elem.msRequestFullscreen) { // IE/Edge
            elem.msRequestFullscreen();
          }

          // Try to lock orientation to landscape if supported
          if (screen.orientation && screen.orientation.lock) {
            screen.orientation.lock('landscape').catch(function(error) {
              console.log('Orientation lock failed:', error);
            });
          }
        }

        // Handle iOS-specific setup
        if (isIOS()) {
          console.log('iOS detected');

          // If not in standalone mode, show install prompt after delay
          if (!isStandalone()) {
            // Hide fullscreen button on iOS (it doesn't work)
            if (fullscreenBtn) {
              fullscreenBtn.classList.add('hidden');
            }

            // Shared flag to prevent showing prompt multiple times
            let hasShownPrompt = false;

            function showInstallPrompt() {
              if (!hasShownPrompt && iosInstallPrompt) {
                hasShownPrompt = true;
                iosInstallPrompt.classList.add('show');
                // Remove event listener once we've shown the prompt
                document.removeEventListener('touchstart', showInstallPromptOnTouch);
              }
            }

            function showInstallPromptOnTouch(e) {
              // Don't show if user is clicking the dismiss button
              if (e.target.closest('#ios-install-prompt')) {
                return;
              }
              showInstallPrompt();
            }

            // Show iOS install prompt after 3 seconds
            setTimeout(function() {
              showInstallPrompt();
            }, 3000);

            // Also allow showing on first interaction (if 3 seconds hasn't passed yet)
            document.addEventListener('touchstart', showInstallPromptOnTouch);
          } else {
            // In standalone mode - hide the prompt and fullscreen button
            if (iosInstallPrompt) {
              iosInstallPrompt.style.display = 'none';
            }
            if (fullscreenBtn) {
              fullscreenBtn.classList.add('hidden');
            }
            console.log('Running in standalone mode');
          }
        } else {
          // Non-iOS: Initialize fullscreen button
          if (fullscreenBtn) {
            fullscreenBtn.addEventListener('click', requestFullscreen);
          }

          // Auto-request fullscreen on first user interaction (non-iOS mobile)
          if (isMobile()) {
            let hasInteracted = false;

            function attemptFullscreen() {
              if (!hasInteracted && !document.fullscreenElement) {
                hasInteracted = true;

                setTimeout(function() {
                  requestFullscreen();
                }, 100);

                document.removeEventListener('touchstart', attemptFullscreen);
                document.removeEventListener('click', attemptFullscreen);
              }
            }

            document.addEventListener('touchstart', attemptFullscreen);
            document.addEventListener('click', attemptFullscreen);
          }
        }

        // Check orientation on load and orientation change
        checkOrientation();
        window.addEventListener('orientationchange', checkOrientation);
        window.addEventListener('resize', checkOrientation);

        // Prevent pull-to-refresh on mobile
        document.body.addEventListener('touchmove', function(e) {
          if (e.target === document.body) {
            e.preventDefault();
          }
        }, { passive: false });

        // Handle fullscreen change events
        document.addEventListener('fullscreenchange', function() {
          if (document.fullscreenElement) {
            console.log('Entered fullscreen mode');
          } else {
            console.log('Exited fullscreen mode');
          }
        });

        // Minimal UI: Keep viewport at top on scroll (helps minimize address bar on some browsers)
        let scrollTimeout;
        window.addEventListener('scroll', function() {
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(function() {
            if (window.scrollY > 0) {
              window.scrollTo(0, 0);
            }
          }, 100);
        });

        // Try to minimize address bar by ensuring page height
        function adjustViewport() {
          if (isMobile() && !isStandalone()) {
            document.documentElement.style.height = '100%';
            document.body.style.height = '100%';
          }
        }

        window.addEventListener('load', adjustViewport);
        window.addEventListener('resize', adjustViewport);
      })();
    </script>
  </body>
</html>
